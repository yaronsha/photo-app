# Keep the deploy bundle small + under the 250MB function limit.
# Local data + blobs (live in Supabase/R2 in prod):
data/
photos/
*.db
photos.bak.*.db
chroma/
# Python + tooling cruft:
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
tests/
# Frontend source (only the built dist/ is shipped, via includeFiles):
app/web/node_modules/
# Env files — never ship secrets to the build (VITE_* come from Vercel env at build):
.env
.env.*
*.env
# Markdown — docs only, never imported at runtime (matches at any depth):
*.md
# Dev-only:
docs/
.claude/
