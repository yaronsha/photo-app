{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI Server",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.api.main:app",
        "--reload",
        "--host", "127.0.0.1",
        "--port", "8000"
      ],
      "jinja": true,
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "FastAPI Server (Local Postgres)",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.api.main:app",
        "--reload",
        "--host", "127.0.0.1",
        "--port", "8000"
      ],
      "jinja": true,
      "justMyCode": true,
      "envFile": "${workspaceFolder}/.env.local.no-secrets",
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "ENV_FILE": ".env.local.no-secrets",
        "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "Indexer CLI",
      "type": "python",
      "request": "launch",
      "module": "app.indexer.cli",
      "args": [
        "--step", "scan"
      ],
      "jinja": true,
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "pytest",
      "type": "python",
      "request": "launch",
      "module": "pytest",
      "args": [
        "tests/",
        "-v"
      ],
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "console": "integratedTerminal"
    }
  ]
}
