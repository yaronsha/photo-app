OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...  # reserved for Phase 2

# Postgres (used when DATABASE_URL is set; SQLite is default otherwise)
# Start local container: scripts/pg.sh start
DATABASE_URL=postgresql+psycopg://photos:photos@localhost:5432/photos
DATABASE_URL_DIRECT=postgresql+psycopg://photos:photos@localhost:5432/photos

# Override Docker container defaults (optional)
# PG_USER=photos
# PG_PASSWORD=photos
# PG_DB=photos
# PG_PORT=5432
